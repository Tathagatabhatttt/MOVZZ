// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Enums ──────────────────────────────────────────────

enum BookingState {
  SEARCHING
  CONFIRMED
  IN_PROGRESS
  COMPLETED
  FAILED
  CANCELLED
  MANUAL_ESCALATION
}

enum TripType {
  HIGH_RELIABILITY
  STANDARD
}

enum ProviderType {
  INDIVIDUAL_DRIVER
  FLEET_OPERATOR
}

enum PayoutStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
}

enum TransportMode {
  CAB
  BIKE
  AUTO
  METRO
}

// ─── Models ─────────────────────────────────────────────

model User {
  id              String    @id @default(cuid())
  phone           String    @unique
  name            String?
  email           String?
  profilePhotoKey String?   // S3 object key — e.g. users/{id}/profile.jpg
  referralCode    String    @unique
  referredBy      String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  lastLoginAt     DateTime?
  role            String    @default("user")

  bookings     Booking[]
  credits      UserCredit[]
  favorites    FavoriteLocation[]
  subscription Subscription?

  @@index([phone])
  @@index([referralCode])
}

model Booking {
  id                 String        @id @default(cuid())
  userId             String
  userPhone          String
  pickup             String
  pickupLat          Float?
  pickupLng          Float?
  dropoff            String
  dropoffLat         Float?
  dropoffLng         Float?
  tripType           TripType      @default(HIGH_RELIABILITY)
  transportMode      TransportMode @default(CAB)
  providerId         String?
  providerType       ProviderType?
  state              BookingState
  previousState      BookingState?
  fareEstimate       Int
  fareActual         Int?
  commissionRate     Float         @default(0.10)
  commissionAmount   Int?
  createdAt          DateTime      @default(now())
  updatedAt          DateTime      @updatedAt
  confirmedAt        DateTime?
  startedAt          DateTime?
  completedAt        DateTime?
  failedAt           DateTime?
  timeoutAt          DateTime?
  recoveryAttempts   Int           @default(0)
  manualIntervention Boolean       @default(false)
  metadata           Json?
  razorpayOrderId        String?
  razorpayPaymentId      String?
  paidAt                 DateTime?

  // AI orchestration fields (Week 1)
  orchestrationStrategy  String?
  orchestrationReasoning String?
  aiReliabilityScore     Float?
  contextSnapshot        Json?
  timeToConfirm          Int?      // seconds from SEARCHING → CONFIRMED

  // Section 2 additions
  scheduledFor     DateTime?   // null = now, set = future scheduled ride
  stopPoints       Json?       // [{label, lat, lng}] for multi-stop trips
  promoCode        String?     // applied promo code
  promoDiscount    Int?        // discount in paise
  sharedWithSos    Boolean     @default(false)

  // Mock / real provider driver details (populated after provider API call)
  driverName       String?
  driverPhone      String?
  driverVehicle    String?     // e.g. "Honda City (TN01AB1234)"
  driverEta        Int?        // minutes to arrival

  user         User              @relation(fields: [userId], references: [id])
  provider     Provider?         @relation(fields: [providerId], references: [id])
  attempts     BookingAttempt[]
  logs         BookingLog[]
  rating       Rating?
  chatMessages ChatMessage[]
  shareTokens  ShareToken[]
  fareSplit    FareSplit?

  @@index([userId])
  @@index([userPhone])
  @@index([state])
  @@index([createdAt])
  @@index([providerId])
  @@index([timeoutAt])
  @@index([scheduledFor])
}

model Provider {
  id              String        @id @default(cuid())
  name            String
  phone           String        @unique
  type            ProviderType
  vehicleModel    String?
  vehiclePlate    String?
  apiEndpoint     String?
  commissionRate  Float         @default(0.10)
  paymentTerms    String        @default("T+2")
  active              Boolean       @default(true)
  pausedUntil         DateTime?
  pauseReason         String?
  currentActiveRides  Int           @default(0)
  maxCapacity         Int           @default(5)
  reliability     Float         @default(0.85)
  rating          Float         @default(4.5)
  totalRides      Int           @default(0)
  successfulRides Int           @default(0)
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  lastActiveAt    DateTime?
  isOnline        Boolean       @default(false)
  lastLat         Float?
  lastLng         Float?

  bookings      Booking[]
  metrics       ProviderMetric[]
  attempts      BookingAttempt[]
  payouts       Payout[]
  metricsCache  ProviderMetricsCache[]
  ratings       Rating[]

  @@index([type])
  @@index([active])
  @@index([reliability])
  @@index([phone])
}

model ProviderMetric {
  id                 String   @id @default(cuid())
  providerId         String
  date               DateTime @db.Date
  totalBookings      Int      @default(0)
  successfulBookings Int      @default(0)
  cancelledBookings  Int      @default(0)
  rejectedBookings   Int      @default(0)
  failedBookings     Int      @default(0)
  avgResponseTime    Int?
  avgAcceptanceTime  Int?
  onTimePickups      Int      @default(0)
  latePickups        Int      @default(0)
  reliabilityScore   Float    @default(0.0)
  onTimeRate         Float    @default(0.0)
  totalRevenue       Int      @default(0)
  totalCommission    Int      @default(0)

  provider Provider @relation(fields: [providerId], references: [id])

  @@unique([providerId, date])
  @@index([date])
  @@index([reliabilityScore])
}

model BookingAttempt {
  id            String   @id @default(cuid())
  bookingId     String
  providerId    String
  attemptNumber Int
  success       Boolean
  responseTime  Int?
  errorMessage  String?
  score         Float?
  reliability   Float?
  eta           Int?
  fare          Int?
  createdAt     DateTime @default(now())
  metadata      Json?

  booking  Booking  @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  provider Provider @relation(fields: [providerId], references: [id])

  @@index([bookingId])
  @@index([providerId])
  @@index([success])
}

model BookingLog {
  id        String   @id @default(cuid())
  bookingId String
  event     String
  message   String
  metadata  Json?
  createdAt DateTime @default(now())

  booking Booking @relation(fields: [bookingId], references: [id], onDelete: Cascade)

  @@index([bookingId])
  @@index([event])
  @@index([createdAt])
}

model UserCredit {
  id              String    @id @default(cuid())
  userId          String
  userPhone       String
  amount          Int
  reason          String
  issued          DateTime  @default(now())
  used            Boolean   @default(false)
  usedAt          DateTime?
  usedInBookingId String?
  expiresAt       DateTime

  user User @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([userPhone])
  @@index([used])
  @@index([expiresAt])
}

model Payout {
  id               String       @id @default(cuid())
  providerId       String
  totalRides       Int
  totalRevenue     Int
  commissionAmount Int
  netPayout        Int
  status           PayoutStatus @default(PENDING)
  createdAt        DateTime     @default(now())
  paidAt           DateTime?
  paymentMethod    String?
  transactionId    String?

  provider Provider @relation(fields: [providerId], references: [id])

  @@index([providerId])
  @@index([status])
  @@index([createdAt])
}

// AI Week 2 — cached aggregated provider metrics (avoids recomputing on every request)
model ProviderMetricsCache {
  id         String   @id @default(cuid())
  providerId String
  cacheKey   String   @unique   // e.g. "provider:metrics:<id>"
  data       Json
  computedAt DateTime @default(now())
  expiresAt  DateTime

  provider Provider @relation(fields: [providerId], references: [id])

  @@index([providerId])
  @@index([expiresAt])
}

// AI Week 2 — training data collected after every COMPLETED / FAILED booking
model MLTrainingData {
  id                   String   @id @default(cuid())
  bookingId            String   @unique
  providerId           String
  transportMode        String
  distanceKm           Float?
  hourOfDay            Int
  dayOfWeek            Int
  surgeMultiplier      Float?
  predictedScore       Float?
  actualOutcome        String   // COMPLETED | FAILED | CANCELLED
  timeToConfirmSec     Int?
  orchestrationStrategy String?
  contextSnapshot      Json?
  createdAt            DateTime @default(now())

  @@index([providerId])
  @@index([actualOutcome])
  @@index([transportMode])
  @@index([createdAt])
}

// AI Week 3 — demand forecasts per zone/hour (populated nightly by demand-forecast worker)
model DemandForecast {
  id               String   @id @default(cuid())
  zone             String
  forecastHour     DateTime
  predictedRides   Float
  confidenceLow    Float
  confidenceHigh   Float
  actualRides      Int?
  forecastAccuracy Float?
  createdAt        DateTime @default(now())

  @@unique([zone, forecastHour])
  @@index([zone])
  @@index([forecastHour])
}

// ─── Section 2 Models ────────────────────────────────────

// Section 2 — Ratings & Reviews
model Rating {
  id         String   @id @default(cuid())
  bookingId  String   @unique
  userId     String
  providerId String?
  score      Int      // 1–5 stars
  comment    String?
  createdAt  DateTime @default(now())

  booking  Booking   @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  provider Provider? @relation(fields: [providerId], references: [id])

  @@index([userId])
  @@index([providerId])
}

// Section 2 — Favorite Locations
model FavoriteLocation {
  id        String   @id @default(cuid())
  userId    String
  label     String   // "Home", "Work", or custom name
  name      String   // full place name
  lat       Float
  lng       Float
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

// Section 2 — Promo Codes
model PromoCode {
  id              String   @id @default(cuid())
  code            String   @unique
  discountPaise   Int      // flat discount in paise
  discountPercent Float?   // % discount (applied up to maxDiscountPaise)
  maxDiscountPaise Int?    // cap for percent discounts
  minFarePaise    Int      @default(0) // minimum booking fare to apply
  maxUsage        Int      @default(100)
  usageCount      Int      @default(0)
  expiresAt       DateTime
  active          Boolean  @default(true)
  createdAt       DateTime @default(now())

  @@index([code])
  @@index([active])
}

// Section 2 — In-app Chat Messages
model ChatMessage {
  id        String   @id @default(cuid())
  bookingId String
  sender    String   // "user" | "provider"
  senderPhone String?
  message   String
  createdAt DateTime @default(now())

  booking Booking @relation(fields: [bookingId], references: [id], onDelete: Cascade)

  @@index([bookingId])
  @@index([createdAt])
}

// Section 2 — Fare Split
model FareSplit {
  id           String   @id @default(cuid())
  bookingId    String   @unique
  totalPaise   Int
  perPersonPaise Int
  participants Int      @default(2)
  shareLink    String   @unique
  status       String   @default("PENDING") // PENDING | SETTLED
  createdAt    DateTime @default(now())

  booking Booking @relation(fields: [bookingId], references: [id], onDelete: Cascade)

  @@index([shareLink])
}

// Section 2 — Live Trip Share Tokens
model ShareToken {
  id        String   @id @default(cuid())
  bookingId String
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())

  booking Booking @relation(fields: [bookingId], references: [id], onDelete: Cascade)

  @@index([token])
  @@index([bookingId])
}

// MOVZZY Pass — user subscription plans
model Subscription {
  id          String   @id @default(cuid())
  userId      String   @unique
  plan        String   // "LITE" | "PLUS" | "PRO"
  status      String   @default("ACTIVE") // "ACTIVE" | "EXPIRED" | "CANCELLED"
  discountPct Float    // 0.05 | 0.10 | 0.15
  noSurge     Boolean  @default(true)
  startDate   DateTime @default(now())
  expiresAt   DateTime
  autoRenew   Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user User @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([status])
  @@index([expiresAt])
}
